{
  "name": "grav-svelte",
  "version": "0.1.235",
  "description": "A collection of Svelte components",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./Modals": {
      "types": "./dist/Modals/index.d.ts",
      "svelte": "./dist/Modals/index.js"
    },
    "./Inputs": {
      "types": "./dist/Inputs/index.d.ts",
      "svelte": "./dist/Inputs/index.js"
    },
    "./Sidebar": {
      "types": "./dist/Sidebar/index.d.ts",
      "svelte": "./dist/Sidebar/index.js"
    },
    "./CRUD": {
      "types": "./dist/CRUD/index.d.ts",
      "svelte": "./dist/CRUD/index.js"
    },
    "./Alerts": {
      "types": "./dist/Alerts/index.d.ts",
      "svelte": "./dist/Alerts/index.js"
    },
    "./typography.css": "./dist/typography.css"
  },
  "dependencies": {
    "grav-svelte": "^0.1.211",
    "xlsx": "^0.18.5"
  },
  "peerDependencies": {
    "svelte": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "svelte-select": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.8",
    "publint": "^0.3.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-select": "^5.8.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.0.0",
    "vite": "^6.2.6"
  },
  "keywords": [
    "svelte",
    "components",
    "ui",
    "button"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/grav-svelte.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/grav-svelte/issues"
  },
  "homepage": "https://github.com/yourusername/grav-svelte#readme",
  "author": "Your Name",
  "publishConfig": {
    "access": "public"
  }
}
